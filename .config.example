# PHPHarbor - Configuration Example
# This file is automatically generated by the 'phpharbor setup init'
# or 'phpharbor setup config' command

# Directory where projects are saved
# Default: ./projects (relative to installation directory)
# Custom examples:
#   PROJECTS_DIR="/Users/name/Development/docker-projects"
#   PROJECTS_DIR="$HOME/Projects/docker"
#   PROJECTS_DIR="/mnt/data/docker-projects"
PROJECTS_DIR="./projects"

# Proxy service ports
# Default: HTTP=8080, HTTPS=8443
# Modify if you have port conflicts or different preferences
HTTP_PORT=8080
HTTPS_PORT=8443

# Shared services ports
# Default: MySQL=3306, Redis=6379
# Modify if you want to use non-standard ports
MYSQL_SHARED_PORT=3306
REDIS_SHARED_PORT=6379

# Last modified date: (automatically updated)
