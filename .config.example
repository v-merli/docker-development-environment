# PHPHarbor - Configuration Example
# Questo file viene generato automaticamente dal comando 'phpharbor setup init'
# o 'phpharbor setup config'

# Directory dove vengono salvati i progetti
# Default: ./projects (relativo alla directory di installazione)
# Esempi custom:
#   PROJECTS_DIR="/Users/nome/Development/docker-projects"
#   PROJECTS_DIR="$HOME/Projects/docker"
#   PROJECTS_DIR="/mnt/data/docker-projects"
PROJECTS_DIR="./projects"

# Porte servizi Proxy
# Default: HTTP=8080, HTTPS=8443
# Modifica se hai conflitti di porte o preferenze diverse
HTTP_PORT=8080
HTTPS_PORT=8443

# Porte servizi condivisi
# Default: MySQL=3306, Redis=6379
# Modifica se vuoi usare porte non standard
MYSQL_SHARED_PORT=3306
REDIS_SHARED_PORT=6379

# Data ultima modifica: (viene aggiornata automaticamente)
