#!/bin/bash

# Docker Development Environment CLI
# Unified command-line interface for managing Docker projects

set -e

VERSION="2.0.0"

# Colori
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECTS_DIR="$SCRIPT_DIR/projects"
TEMPLATES_DIR="$SCRIPT_DIR/shared/templates"

# Rileva comando docker compose
if command -v docker-compose &> /dev/null; then
    DOCKER_COMPOSE="docker-compose"
elif command -v docker &> /dev/null && docker compose version &> /dev/null; then
    DOCKER_COMPOSE="docker compose"
else
    echo -e "${RED}❌ Errore: Docker Compose non disponibile${NC}"
    exit 1
fi

# Funzioni di output
print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }
print_title() { echo -e "${CYAN}━━━ $1 ━━━${NC}"; }

# Mostra versione
show_version() {
    echo "Docker Development Environment v$VERSION"
}

# Mostra help generale
show_help() {
    cat << EOF
$(show_version)

Usage: ./docker-dev <command> [options]

COMMANDS:

  Project Management:
    create <name>         Crea un nuovo progetto
    list                  Elenca tutti i progetti
    start <name>          Avvia un progetto
    stop <name>           Ferma un progetto
    restart <name>        Riavvia un progetto
    remove <name>         Rimuovi un progetto
    logs <name>           Mostra i log di un progetto
    
  Development Tools:
    shell <name>          Apri shell nel container PHP
    artisan <name> <cmd>  Esegui comando artisan
    composer <name> <cmd> Esegui comando composer
    npm <name> <cmd>      Esegui comando npm
    mysql <name>          Apri MySQL CLI del progetto
    
  Shared Services:
    shared start [svc]    Avvia servizi condivisi (mysql/redis/php)
    shared stop           Ferma servizi condivisi
    shared status         Stato servizi condivisi
    shared logs           Log servizi condivisi
    shared mysql          MySQL CLI condiviso
    shared php <version>  Avvia PHP condiviso (7.3-8.5)
    
  System Setup:
    setup dns             Configura dnsmasq per domini .test
    setup proxy           Avvia nginx reverse proxy
    setup init            Setup iniziale completo
    
  Information:
    stats                 Mostra statistiche risorse Docker
    info <name>           Informazioni progetto
    version               Mostra versione
    help                  Mostra questo messaggio

EXAMPLES:

  # Setup iniziale
  ./docker-dev setup init
  
  # Crea progetti
  ./docker-dev create myshop --type laravel --php 8.3
  ./docker-dev create blog --fully-shared --php 8.3
  
  # Gestisci progetti
  ./docker-dev list
  ./docker-dev start myshop
  ./docker-dev logs myshop
  ./docker-dev shell myshop
  
  # Servizi condivisi
  ./docker-dev shared start
  ./docker-dev shared php 8.3
  ./docker-dev shared status
  
  # Development
  ./docker-dev artisan myshop migrate
  ./docker-dev composer myshop require laravel/sanctum
  ./docker-dev npm myshop install

Per help specifico: ./docker-dev <command> --help

EOF
}

# Carica moduli
load_module() {
    local module=$1
    local module_file="$SCRIPT_DIR/cli/$module.sh"
    
    if [ -f "$module_file" ]; then
        source "$module_file"
    else
        print_error "Modulo $module non trovato"
        exit 1
    fi
}

# Main
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND=$1
shift

case $COMMAND in
    create)
        load_module "create"
        cmd_create "$@"
        ;;
    list|ls)
        load_module "project"
        cmd_list "$@"
        ;;
    start)
        load_module "project"
        cmd_start "$@"
        ;;
    stop)
        load_module "project"
        cmd_stop "$@"
        ;;
    restart)
        load_module "project"
        cmd_restart "$@"
        ;;
    remove|rm)
        load_module "project"
        cmd_remove "$@"
        ;;
    logs)
        load_module "project"
        cmd_logs "$@"
        ;;
    shell|bash)
        load_module "dev"
        cmd_shell "$@"
        ;;
    artisan)
        load_module "dev"
        cmd_artisan "$@"
        ;;
    composer)
        load_module "dev"
        cmd_composer "$@"
        ;;
    npm)
        load_module "dev"
        cmd_npm "$@"
        ;;
    mysql)
        load_module "dev"
        cmd_mysql "$@"
        ;;
    shared)
        load_module "shared"
        cmd_shared "$@"
        ;;
    setup)
        load_module "setup"
        cmd_setup "$@"
        ;;
    stats)
        load_module "system"
        cmd_stats "$@"
        ;;
    info)
        load_module "system"
        cmd_info "$@"
        ;;
    version|-v|--version)
        show_version
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        print_error "Comando sconosciuto: $COMMAND"
        echo ""
        echo "Usa './docker-dev help' per la lista completa dei comandi"
        exit 1
        ;;
esac
