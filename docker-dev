#!/bin/bash

# Docker Development Environment CLI
# Unified command-line interface for managing Docker projects

set -e

VERSION="1.0.0"

# Colori
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
CONFIG_FILE="$SCRIPT_DIR/.config"
TEMPLATES_DIR="$SCRIPT_DIR/shared/templates"

# Carica configurazione
load_config() {
    # Default
    PROJECTS_DIR="$SCRIPT_DIR/projects"
    HTTP_PORT=8080
    HTTPS_PORT=8443
    MYSQL_SHARED_PORT=3306
    REDIS_SHARED_PORT=6379
    
    # Leggi da config se esiste
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    
    # Esporta per uso negli script caricati
    export PROJECTS_DIR
    export HTTP_PORT
    export HTTPS_PORT
    export MYSQL_SHARED_PORT
    export REDIS_SHARED_PORT
}

# Salva configurazione
save_config() {
    cat > "$CONFIG_FILE" << EOF
# Docker Development Environment - Configuration
# Questo file viene generato automaticamente dal comando 'setup'

# Directory dove vengono salvati i progetti
PROJECTS_DIR="$PROJECTS_DIR"

# Porte servizi (Proxy)
HTTP_PORT=$HTTP_PORT
HTTPS_PORT=$HTTPS_PORT

# Porte servizi condivisi
MYSQL_SHARED_PORT=$MYSQL_SHARED_PORT
REDIS_SHARED_PORT=$REDIS_SHARED_PORT

# Data ultima modifica: $(date)
EOF
    
    # Aggiorna anche il file .env del proxy
    update_proxy_env
}

# Aggiorna file .env del proxy
update_proxy_env() {
    local proxy_env="$SCRIPT_DIR/proxy/.env"
    
    cat > "$proxy_env" << EOF
# Proxy ports configuration
HTTP_PORT=$HTTP_PORT
HTTPS_PORT=$HTTPS_PORT

# Shared services ports (optional)
MYSQL_SHARED_PORT=$MYSQL_SHARED_PORT
REDIS_SHARED_PORT=$REDIS_SHARED_PORT
EOF
}

# Carica build info se disponibile
load_build_info() {
    local build_file="$SCRIPT_DIR/.build-info"
    
    if [ -f "$build_file" ]; then
        source "$build_file"
        BUILD_INFO_LOADED=true
    else
        BUILD_INFO_LOADED=false
        GIT_HASH="dev"
        BUILD_DATE="development"
    fi
}

# Carica config e build info all'avvio
load_config
load_build_info

# Rileva comando docker compose
if command -v docker-compose &> /dev/null; then
    DOCKER_COMPOSE="docker-compose"
elif command -v docker &> /dev/null && docker compose version &> /dev/null; then
    DOCKER_COMPOSE="docker compose"
else
    echo -e "${RED}❌ Errore: Docker Compose non disponibile${NC}"
    exit 1
fi

# Rileva sistema operativo
detect_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if grep -qi microsoft /proc/version 2>/dev/null; then
            echo "wsl"
        else
            echo "linux"
        fi
    else
        echo "unknown"
    fi
}

# Funzioni di output
print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }
print_title() { echo -e "${CYAN}━━━ $1 ━━━${NC}"; }

# Trova porta disponibile (per evitare conflitti)
find_available_port() {
    local base_port=$1
    local range=${2:-100}
    local port=$base_port
    
    local used_ports=$(docker ps --format '{{.Ports}}' | grep -oE '0\.0\.0\.0:[0-9]+' | cut -d':' -f2 | sort -n)
    local env_ports=$(find "$PROJECTS_DIR" -name ".env" -exec grep "^VITE_PORT=" {} \; 2>/dev/null | cut -d'=' -f2 | sort -n)
    local all_ports=$(echo -e "$used_ports\n$env_ports" | sort -n | uniq)
    
    while [ $port -lt $((base_port + range)) ]; do
        if ! echo "$all_ports" | grep -q "^${port}$"; then
            echo "$port"
            return 0
        fi
        ((port++))
    done
    
    echo $((base_port + RANDOM % range))
}

# Mostra versione
show_version() {
    if [ "$BUILD_INFO_LOADED" = "true" ]; then
        echo "Docker Development Environment v$VERSION ($GIT_HASH)"
    else
        # Prova a leggere hash corrente (sviluppo)
        local current_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "dev")
        echo "Docker Development Environment v$VERSION ($current_hash)"
    fi
}

# Mostra help generale
show_help() {
    cat << EOF
$(show_version)

Usage: ./docker-dev <command> [options]

COMMANDS:

  Project Management:
    create <name>         Crea un nuovo progetto
    list                  Elenca tutti i progetti
    start <name>          Avvia un progetto
    stop <name>           Ferma un progetto
    restart <name>        Riavvia un progetto
    remove <name>         Rimuovi un progetto
    logs <name>           Mostra i log di un progetto
    
  Development Tools:
    shell <name>          Apri shell nel container PHP
    artisan <name> <cmd>  Esegui comando artisan
    composer <name> <cmd> Esegui comando composer
    npm <name> <cmd>      Esegui comando npm
    mysql <name>          Apri MySQL CLI del progetto
    
  Shared Services:
    shared start [svc]    Avvia servizi condivisi (mysql/redis/php)
    shared stop           Ferma servizi condivisi
    shared status         Stato servizi condivisi
    shared logs           Log servizi condivisi
    shared mysql          MySQL CLI condiviso
    shared php <version>  Avvia PHP condiviso (7.3-8.5)
    
  SSL Management:
    ssl setup             Configura CA locale per HTTPS
    ssl generate <domain> Genera certificato SSL
    ssl verify            Verifica configurazione SSL
    ssl install           Installa/reinstalla CA
    
  System Setup:
    setup config          Configura directory progetti
    setup ports           Configura porte servizi (HTTP, HTTPS, MySQL, Redis)
    setup dns             Configura dnsmasq per domini .test
    setup proxy           Avvia nginx reverse proxy
    setup init            Setup iniziale completo
    
  System Update:
    update check          Verifica disponibilità aggiornamenti
    update install        Installa l'ultima versione
    update changelog      Mostra changelog ultima versione
    
  Information:
    stats                 Mostra statistiche risorse Docker
    info <name>           Informazioni progetto
    version               Mostra versione
    help                  Mostra questo messaggio

EXAMPLES:

  # Setup iniziale
  ./docker-dev setup init
  
  # Crea progetti
  ./docker-dev create myshop --type laravel --php 8.3
  ./docker-dev create blog --fully-shared --php 8.3
  
  # Gestisci progetti
  ./docker-dev list
  ./docker-dev start myshop
  ./docker-dev logs myshop
  ./docker-dev shell myshop
  
  # Servizi condivisi
  ./docker-dev shared start
  ./docker-dev shared php 8.3
  ./docker-dev shared status
  
  # Development
  ./docker-dev artisan myshop migrate
  ./docker-dev composer myshop require laravel/sanctum
  ./docker-dev npm myshop install

Per help specifico: ./docker-dev <command> --help

EOF
}

# Carica moduli
load_module() {
    local module=$1
    local module_file="$SCRIPT_DIR/cli/$module.sh"
    
    if [ -f "$module_file" ]; then
        source "$module_file"
    else
        print_error "Modulo $module non trovato"
        exit 1
    fi
}

# Main
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND=$1
shift

case $COMMAND in
    create)
        load_module "create"
        cmd_create "$@"
        ;;
    list|ls)
        load_module "project"
        cmd_list "$@"
        ;;
    start)
        load_module "project"
        cmd_start "$@"
        ;;
    stop)
        load_module "project"
        cmd_stop "$@"
        ;;
    restart)
        load_module "project"
        cmd_restart "$@"
        ;;
    remove|rm)
        load_module "project"
        cmd_remove "$@"
        ;;
    logs)
        load_module "project"
        cmd_logs "$@"
        ;;
    shell|bash)
        load_module "dev"
        cmd_shell "$@"
        ;;
    artisan)
        load_module "dev"
        cmd_artisan "$@"
        ;;
    composer)
        load_module "dev"
        cmd_composer "$@"
        ;;
    npm)
        load_module "dev"
        cmd_npm "$@"
        ;;
    mysql)
        load_module "dev"
        cmd_mysql "$@"
        ;;
    shared)
        load_module "shared"
        cmd_shared "$@"
        ;;
    ssl)
        load_module "ssl"
        cmd_ssl "$@"
        ;;
    setup)
        load_module "setup"
        cmd_setup "$@"
        ;;
    update)
        load_module "update"
        cmd_update "$@"
        ;;
    stats)
        load_module "system"
        cmd_stats "$@"
        ;;
    info)
        load_module "system"
        cmd_info "$@"
        ;;
    version|-v|--version)
        show_version
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        print_error "Comando sconosciuto: $COMMAND"
        echo ""
        echo "Usa './docker-dev help' per la lista completa dei comandi"
        exit 1
        ;;
esac
