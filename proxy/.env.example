# Proxy ports configuration
# Copy this file to .env and adjust values as needed

# HTTP port (default: 8080)
# Set to 80 if not conflicting with other services
HTTP_PORT=8080

# HTTPS port (default: 8443)
# Set to 443 if not conflicting with other services
HTTPS_PORT=8443

# Shared MySQL port (default: 3306)
# Only used when starting shared services with --profile shared-services
MYSQL_SHARED_PORT=3306

# Shared Redis port (default: 6379)
# Only used when starting shared services with --profile shared-services
REDIS_SHARED_PORT=6379
