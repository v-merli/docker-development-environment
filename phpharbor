#!/bin/bash

# PHPHarbor CLI
# Unified command-line interface for managing php projects with Docker

set -e

VERSION="1.0.0"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Directories
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
CONFIG_FILE="$SCRIPT_DIR/.config"
TEMPLATES_DIR="$SCRIPT_DIR/shared/templates"

# Load configuration
load_config() {
    # Defaults
    PROJECTS_DIR="$SCRIPT_DIR/projects"
    HTTP_PORT=8080
    HTTPS_PORT=8443
    MYSQL_SHARED_PORT=3306
    REDIS_SHARED_PORT=6379
    
    # Read from config if exists
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    
    # Export for use in loaded scripts
    export PROJECTS_DIR
    export HTTP_PORT
    export HTTPS_PORT
    export MYSQL_SHARED_PORT
    export REDIS_SHARED_PORT
}

# Save configuration
save_config() {
    cat > "$CONFIG_FILE" << EOF
# PHPHarbor - Configuration
# This file is automatically generated by the 'setup' command

# Directory where projects are stored
PROJECTS_DIR="$PROJECTS_DIR"

# Service ports (Proxy)
HTTP_PORT=$HTTP_PORT
HTTPS_PORT=$HTTPS_PORT

# Shared services ports
MYSQL_SHARED_PORT=$MYSQL_SHARED_PORT
REDIS_SHARED_PORT=$REDIS_SHARED_PORT

# Last modified: $(date)
EOF
    
    # Also update proxy .env file
    update_proxy_env
}

# Update proxy .env file
update_proxy_env() {
    local proxy_env="$SCRIPT_DIR/proxy/.env"
    
    cat > "$proxy_env" << EOF
# Proxy ports configuration
HTTP_PORT=$HTTP_PORT
HTTPS_PORT=$HTTPS_PORT

# Shared services ports (optional)
MYSQL_SHARED_PORT=$MYSQL_SHARED_PORT
REDIS_SHARED_PORT=$REDIS_SHARED_PORT
EOF
}

# Load build info if available
load_build_info() {
    local build_file="$SCRIPT_DIR/.build-info"
    
    if [ -f "$build_file" ]; then
        source "$build_file"
        BUILD_INFO_LOADED=true
    else
        BUILD_INFO_LOADED=false
        GIT_HASH="dev"
        BUILD_DATE="development"
    fi
}

# Load config and build info on startup
load_config
load_build_info

# Detect docker compose command
if command -v docker-compose &> /dev/null; then
    DOCKER_COMPOSE="docker-compose"
elif command -v docker &> /dev/null && docker compose version &> /dev/null; then
    DOCKER_COMPOSE="docker compose"
else
    echo -e "${RED}❌ Error: Docker Compose not available${NC}"
    exit 1
fi

# Detect operating system
detect_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if grep -qi microsoft /proc/version 2>/dev/null; then
            echo "wsl"
        else
            echo "linux"
        fi
    else
        echo "unknown"
    fi
}

# Output functions
print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }
print_title() { echo -e "${CYAN}━━━ $1 ━━━${NC}"; }

# Find available port (to avoid conflicts)
find_available_port() {
    local base_port=$1
    local range=${2:-100}
    local port=$base_port
    
    local used_ports=$(docker ps --format '{{.Ports}}' | grep -oE '0\.0\.0\.0:[0-9]+' | cut -d':' -f2 | sort -n)
    local env_ports=$(find "$PROJECTS_DIR" -name ".env" -exec grep "^VITE_PORT=" {} \; 2>/dev/null | cut -d'=' -f2 | sort -n)
    local all_ports=$(echo -e "$used_ports\n$env_ports" | sort -n | uniq)
    
    while [ $port -lt $((base_port + range)) ]; do
        if ! echo "$all_ports" | grep -q "^${port}$"; then
            echo "$port"
            return 0
        fi
        ((port++))
    done
    
    echo $((base_port + RANDOM % range))
}

# Show version
show_version() {
    if [ "$BUILD_INFO_LOADED" = "true" ]; then
        echo "PHPHarbor v$VERSION ($GIT_HASH)"
    else
        # Try to read current hash (development)
        local current_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "dev")
        echo "PHPHarbor v$VERSION ($current_hash)"
    fi
}

# Show general help
show_help() {
    cat << EOF
$(show_version)

Usage: ./phpharbor <command> [options]

COMMANDS:

  Project Management:
    create <name>         Create a new project
    list                  List all projects
    start <name>          Start a project
    stop <name>           Stop a project
    restart <name>        Restart a project
    remove <name>         Remove a project
    logs <name>           Show project logs
    convert <name> <type> Convert project type (laravel/wordpress/php)
    
  Development Tools:
    shell <name>          Open shell in PHP container
    artisan <name> <cmd>  Run artisan command
    composer <name> <cmd> Run composer command
    npm <name> <cmd>      Run npm command
    mysql <name>          Open project MySQL CLI
    queue <name> <action> Manage queue worker (restart|logs|status)
    
  Shared Services:
    shared start [svc]    Start shared services (mysql/redis/php)
    shared stop           Stop shared services
    shared status         Shared services status
    shared logs           Shared services logs
    shared mysql          Shared MySQL CLI
    shared php <version>  Start shared PHP (7.3-8.5)
    
  SSL Management:
    ssl setup             Setup local CA for HTTPS
    ssl generate <domain> Generate SSL certificate
    ssl verify            Verify SSL configuration
    ssl install           Install/reinstall CA
    
  System Setup:
    setup config          Configure projects directory
    setup ports           Configure service ports (HTTP, HTTPS, MySQL, Redis)
    setup dns             Configure dnsmasq for .test domains
    setup proxy           Start nginx reverse proxy
    setup init            Complete initial setup
    
  System Update:
    update check          Check for updates
    update install        Install latest version
    update changelog      Show latest changelog
    
  Information:
    stats [command]       Show resource usage statistics
      resources           Show CPU/RAM usage (default)
      disk                Disk usage analysis
      disk --detailed     Per-project breakdown
      disk --compare      Compare shared vs dedicated
      disk --cleanup      Remove orphan volumes and images
    info <name>           Project information
    cleanup               Clean orphaned SSL certificates and volume directories
    reset <command>       Reset Docker environment
      soft                Remove containers only (keep data)
      hard                Complete reset (removes all data - DATA LOSS!)
      status              Show current Docker status
    version               Show version
    help                  Show this message

EXAMPLES:

  # Initial setup
  ./phpharbor setup init
  
  # Create projects
  ./phpharbor create myshop --type laravel --php 8.3
  ./phpharbor create blog --fully-shared --php 8.3
  
  # Manage projects
  ./phpharbor list
  ./phpharbor start myshop
  ./phpharbor logs myshop
  ./phpharbor shell myshop
  
  # Shared services
  ./phpharbor shared start
  ./phpharbor shared php 8.3
  ./phpharbor shared status
  
  # Development
  ./phpharbor artisan myshop migrate
  ./phpharbor composer myshop require laravel/sanctum
  ./phpharbor npm myshop install
  ./phpharbor queue myshop restart
  
  # Statistics
  ./phpharbor stats disk
  ./phpharbor stats disk --compare

For specific help: ./phpharbor <command> --help

EOF
}

# Load modules
load_module() {
    local module=$1
    local module_file="$SCRIPT_DIR/cli/$module.sh"
    
    if [ -f "$module_file" ]; then
        source "$module_file"
    else
        print_error "Module $module not found"
        exit 1
    fi
}

# Main
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND=$1
shift

case $COMMAND in
    create)
        load_module "create"
        cmd_create "$@"
        ;;
    list|ls)
        load_module "project"
        cmd_list "$@"
        ;;
    start)
        load_module "project"
        cmd_start "$@"
        ;;
    stop)
        load_module "project"
        cmd_stop "$@"
        ;;
    restart)
        load_module "project"
        cmd_restart "$@"
        ;;
    remove|rm)
        load_module "project"
        cmd_remove "$@"
        ;;
    logs)
        load_module "project"
        cmd_logs "$@"
        ;;
    convert)
        load_module "convert"
        cmd_convert "$@"
        ;;
    shell|bash)
        load_module "dev"
        cmd_shell "$@"
        ;;
    artisan)
        load_module "dev"
        cmd_artisan "$@"
        ;;
    composer)
        load_module "dev"
        cmd_composer "$@"
        ;;
    npm)
        load_module "dev"
        cmd_npm "$@"
        ;;
    mysql)
        load_module "dev"
        cmd_mysql "$@"
        ;;
    queue)
        load_module "dev"
        cmd_queue "$@"
        ;;
    shared)
        load_module "shared"
        cmd_shared "$@"
        ;;
    ssl)
        load_module "ssl"
        cmd_ssl "$@"
        ;;
    setup)
        load_module "setup"
        cmd_setup "$@"
        ;;
    update)
        load_module "update"
        cmd_update "$@"
        ;;
    stats)
        load_module "system"
        cmd_stats "$@"
        ;;
    info)
        load_module "system"
        cmd_info "$@"
        ;;
    cleanup)
        load_module "system"
        cmd_cleanup "$@"
        ;;
    reset)
        load_module "reset"
        cmd_reset "$@"
        ;;
    version|-v|--version)
        show_version
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        print_error "Unknown command: $COMMAND"
        echo ""
        echo "Use './phpharbor help' for the complete list of commands"
        exit 1
        ;;
esac
