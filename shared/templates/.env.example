# Project Environment Configuration
# Copy this file to .env and customize for your project

# Project name (used for container names)
PROJECT_NAME=my-project

# Project type (laravel, wordpress, php, html)
PROJECT_TYPE=laravel

# Domain configuration
DOMAIN=my-project.test
LETSENCRYPT_EMAIL=dev@localhost

# Nginx configuration file (laravel.conf, wordpress.conf, php.conf, html.conf)
NGINX_CONF=laravel.conf

# PHP version (7.3, 7.4, 8.1, 8.2, 8.3, 8.5)
PHP_VERSION=8.3

# Node.js version (18, 20, 21)
NODE_VERSION=20

# MySQL configuration
MYSQL_DATABASE=my_database
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=laravel
MYSQL_PASSWORD=secret

# MySQL version
MYSQL_VERSION=8.0

# Redis configuration
REDIS_PORT=6379
