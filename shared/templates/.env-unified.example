# Project Environment Configuration
# Generated by docker-dev CLI

# ============================================
# PROJECT BASICS
# ============================================
PROJECT_NAME=my-project
PROJECT_TYPE=laravel
DOMAIN=my-project.test
LETSENCRYPT_EMAIL=dev@localhost

# ============================================
# WEB SERVER
# ============================================
# Nginx configuration file (laravel.conf, wordpress.conf, php.conf, html.conf)
NGINX_CONF=laravel.conf

# ============================================
# VERSIONS
# ============================================
# PHP version (7.3, 7.4, 8.1, 8.2, 8.3, 8.4, 8.5)
PHP_VERSION=8.4

# Node.js version (18, 20, 21)
NODE_VERSION=20

# MySQL version (5.7, 8.0)
MYSQL_VERSION=8.0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Database service to use: 'mysql' (dedicated) or 'mysql-shared'
DB_SERVICE=mysql
DB_HOST=mysql
DB_CONNECTION=mysql

# MySQL (DEDICATED) - Used only if DB_SERVICE=mysql
MYSQL_DATABASE=my_database
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=laravel
MYSQL_PASSWORD=secret
MYSQL_PORT=13306

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis service to use: 'redis' (dedicated) or 'redis-shared'
REDIS_SERVICE=redis
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# SCHEDULER & QUEUE CONFIGURATION
# ============================================
# Image to use for scheduler/queue:
# - '${PROJECT_NAME}-app' (default, uses app image)
# - 'php-shared-${PHP_VERSION}' (uses shared PHP-FPM)
SCHEDULER_IMAGE=${PROJECT_NAME}-app
QUEUE_IMAGE=${PROJECT_NAME}-app

# ============================================
# VITE DEV SERVER
# ============================================
# Auto-generated unique port for Vite HMR
VITE_PORT=5173

# ============================================
# DOCKER COMPOSE PROFILES
# ============================================
# Profiles to enable (space-separated):
# - app: Main application (always enabled)
# - mysql-dedicated: Local MySQL container
# - redis-dedicated: Local Redis container
# - scheduler: Laravel scheduler
# - queue: Laravel queue worker
#
# Set via COMPOSE_PROFILES environment variable or docker compose --profile
# Default: app mysql-dedicated redis-dedicated scheduler
